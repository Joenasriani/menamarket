{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menamarket.local/specs/rails.schema.json",
  "title": "MENAMarket rails",
  "type": "object",
  "required": [
    "rails",
    "fundingIntents",
    "payoutRequests"
  ],
  "additionalProperties": false,
  "properties": {
    "rails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "direction",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "direction": {
            "enum": [
              "funding",
              "payout",
              "both"
            ]
          },
          "status": {
            "enum": [
              "active",
              "disabled"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "fundingIntents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "actorId",
          "railId",
          "amount",
          "status",
          "createdAtIso"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "actorId": {
            "type": "string",
            "minLength": 1
          },
          "railId": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "status": {
            "enum": [
              "requested",
              "cancelled",
              "completed"
            ]
          },
          "createdAtIso": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "payoutRequests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "actorId",
          "railId",
          "amount",
          "status",
          "createdAtIso"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "actorId": {
            "type": "string",
            "minLength": 1
          },
          "railId": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "status": {
            "enum": [
              "requested",
              "cancelled",
              "completed"
            ]
          },
          "createdAtIso": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
