{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menamarket.local/specs/audit-log.schema.json",
  "title": "MENAMarket audit log",
  "type": "object",
  "required": [
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "action",
          "targetType",
          "targetId",
          "timestampIso",
          "metadata"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "enum": [
              "draft_published"
            ]
          },
          "targetType": {
            "enum": [
              "market_draft"
            ]
          },
          "targetId": {
            "type": "string",
            "minLength": 1
          },
          "timestampIso": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
