{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menamarket.local/specs/actors.schema.json",
  "title": "MENAMarket actors",
  "type": "object",
  "required": [
    "actors"
  ],
  "additionalProperties": false,
  "properties": {
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "username",
          "passwordHash",
          "createdAtIso",
          "updatedAtIso"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "username": {
            "type": "string",
            "minLength": 3
          },
          "passwordHash": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string"
          },
          "createdAtIso": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAtIso": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
