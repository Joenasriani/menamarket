{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://menamarket.local/specs/fills.schema.json",
  "title": "MENAMarket fills",
  "type": "object",
  "required": [
    "fills"
  ],
  "additionalProperties": false,
  "properties": {
    "fills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "marketSlug",
          "outcomeId",
          "buyOrderId",
          "sellOrderId",
          "buyActorId",
          "sellActorId",
          "quantity",
          "price",
          "createdAtIso"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "marketSlug": {
            "type": "string",
            "minLength": 1
          },
          "outcomeId": {
            "type": "string",
            "minLength": 1
          },
          "buyOrderId": {
            "type": "string",
            "minLength": 1
          },
          "sellOrderId": {
            "type": "string",
            "minLength": 1
          },
          "buyActorId": {
            "type": "string",
            "minLength": 1
          },
          "sellActorId": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "createdAtIso": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
