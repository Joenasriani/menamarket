# Copy this file to .env and fill in real values before running.
# In production (Vercel), set all required variables in the Vercel project
# Environment Variables dashboard. NEVER use placeholder values in production.
NODE_ENV=development
MENAMARKET_APP_URL=http://localhost:3000
MENAMARKET_ADMIN_URL=http://localhost:3001
DATABASE_URL=postgresql://username:password@localhost:5432/menamarket
REDIS_URL=redis://localhost:6379

# REQUIRED — change all defaults before deploying to production.
ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_MAX_AGE_SECONDS=43200

# REQUIRED — use a different secret from ADMIN_SESSION_SECRET.
ACTOR_SESSION_SECRET=replace-with-a-different-long-random-secret
ACTOR_SESSION_MAX_AGE_SECONDS=2592000

PAYMENT_RAILS_ENABLED=true
DEFAULT_FUNDING_RAIL=manual
DEFAULT_PAYOUT_RAIL=manual

# OPENROUTER_API_KEY is only required when AI features are used.
# Set this in the Vercel Environment Variables dashboard when deploying.
OPENROUTER_API_KEY=
# Default model for OpenRouter. Uses the free/auto router unless overridden.
OPENROUTER_MODEL=openrouter/auto

# Optional. Base URL for the MENAMarket API.
# In production on Vercel, leave unset or set to your deployed URL (e.g. https://your-app.vercel.app/api).
# When unset, the app defaults to the relative path /api.
MENAMARKET_API=
