NODE_ENV=development
MENAMARKET_APP_URL=http://localhost:3000
MENAMARKET_ADMIN_URL=http://localhost:3001
DATABASE_URL=postgresql://username:password@localhost:5432/menamarket
REDIS_URL=redis://localhost:6379

ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_MAX_AGE_SECONDS=43200

ACTOR_SESSION_SECRET=replace-with-a-different-long-random-secret
ACTOR_SESSION_MAX_AGE_SECONDS=2592000

PAYMENT_RAILS_ENABLED=true
DEFAULT_FUNDING_RAIL=manual
DEFAULT_PAYOUT_RAIL=manual

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto:free

MENAMARKET_API=http://localhost:3000/api
